{
    "compilerOptions": {
        "allowJs": false,
        "baseUrl": ".",
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "resolveJsonModule": true,
        "strict": true,
        "target": "ES2022",
        "types": ["vite/client"]
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "vite.config.js"]
}
