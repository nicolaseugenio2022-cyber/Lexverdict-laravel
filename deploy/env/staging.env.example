APP_NAME=LexVerdict
APP_ENV=staging
APP_KEY=SET_IN_SECRET_MANAGER
APP_DEBUG=false
APP_URL=https://staging.example.gov.ph
APP_TIMEZONE=Asia/Manila

LOG_CHANNEL=stack
LOG_STACK=stderr,slack
LOG_LEVEL=warning
LOG_SLACK_WEBHOOK_URL=SET_IN_SECRET_MANAGER

DB_CONNECTION=pgsql
DB_HOST=SET_IN_SECRET_MANAGER
DB_PORT=5432
DB_DATABASE=lexverdict_staging
DB_USERNAME=SET_IN_SECRET_MANAGER
DB_PASSWORD=SET_IN_SECRET_MANAGER
DB_SSLMODE=require

CACHE_STORE=database
QUEUE_CONNECTION=database
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=180
QUEUE_FAILED_DRIVER=database-uuids

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

FILESYSTEM_DISK=local
DOCUMENT_DISK=local
TRUSTED_PROXIES=10.0.0.0/8

MONITOR_QUEUE_BACKLOG_THRESHOLD=100
MONITOR_QUEUE_AGE_THRESHOLD_SECONDS=300
MONITOR_FAILED_JOBS_THRESHOLD=0
